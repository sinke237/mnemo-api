# Example environment file for mnemo-api
# Copy to `.env` and adjust values for your environment.

# Application environment: development | staging | production
APP_ENV=development
# Set to true to enable debug behaviours
APP_DEBUG=true

# Logging and API
LOG_LEVEL=INFO
API_BASE_URL=http://localhost:8000

# Database (asyncpg)
# For compose this points at the postgres service
DATABASE_URL=postgresql+asyncpg://mnemo:changeme_in_production@postgres:5432/mnemo

# Redis
REDIS_URL=redis://redis:6379/0

# JWT / Auth
# In production replace with a securely generated secret (>=32 chars)
JWT_SECRET_KEY=dev_secret_replace_in_production_with_64_char_hex
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=3600

# Optional: rate limits (defaults shown in code)
RATE_LIMIT_READ_PER_MINUTE=600
RATE_LIMIT_WRITE_PER_MINUTE=120
RATE_LIMIT_ANSWER_PER_MINUTE=60
RATE_LIMIT_IMPORT_PER_HOUR=10
RATE_LIMIT_AUTH_PER_MINUTE=30

# Other example overrides
# CSV max import size in bytes (5MB default)
CSV_MAX_SIZE_BYTES=5242880

# If you use any other environment variables (secrets, third-party keys),
# add them here or in a secure secrets store for production.

# Password reset secret (used to HMAC password reset tokens). In production,
# set to a secure random value (>=32 characters). Do NOT use the dev value
# in production.
PASSWORD_RESET_SECRET=dev_password_reset_secret_replace_in_production_with_64_char_hex

# SMTP / Email settings
# Set SMTP_ENABLED=true in production to enable sending emails.
SMTP_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@mnemo.local
SMTP_USE_TLS=false
# If your SMTP provider requires implicit SSL (SMTPS, typically port 465),
# set this to true. This is separate from STARTTLS controlled by SMTP_USE_TLS.
SMTP_IMPLICIT_SSL=false

# Frontend base URL used to construct links (password reset, confirm). In
# production set this to your front-end HTTPS URL, e.g. https://app.example.com
FRONTEND_BASE_URL=http://localhost:3000
